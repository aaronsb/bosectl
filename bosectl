    cmd("status", "Show all settings")
    cmd("battery", "Battery percentage (just the number)")
    cmd("current", "Current mode name (just the word)")
    cmd("buttons", "Show button mapping")
    print()

    section("Debug")
    cmd("raw <hex>", "Send raw BMAP packet (hex bytes)")
    print()
    sys.exit(1)


def main():
    if len(sys.argv) < 2:
        usage()

    cmd = sys.argv[1].lower()

    if cmd in ("help", "-h", "--help"):
        usage()

    try:
        sock = connect()
    except Exception as e:
        print(f"{C_RED}Connection failed:{C_RESET} {e}", file=sys.stderr)
        print(f"{C_DIM}Is Bluetooth on? Are the headphones paired and connected?{C_RESET}", file=sys.stderr)
        sys.exit(1)

    try:
        if cmd in MODES:
            cmd_mode(sock, cmd)
        elif cmd == "status":
            cmd_status(sock)
        elif cmd == "battery":
            cmd_battery(sock)
        elif cmd == "current":
            cmd_current(sock)
        elif cmd == "profiles":
            cmd_profiles(sock)
        elif cmd == "profile":
            if len(sys.argv) < 3:
                cmd_profiles(sock)
            elif sys.argv[2].lower() in ("set", "create", "add"):
                cmd_profile_set(sock, sys.argv[3:])
            elif sys.argv[2].lower() in ("rm", "delete", "del"):
                if len(sys.argv) < 4:
                    print("Usage: bosectl profile rm <name>", file=sys.stderr)
                    sys.exit(1)
                cmd_profile_rm(sock, sys.argv[3])
            else:
                # "bosectl profile <name> [opts]" as shorthand for profile set
                cmd_profile_set(sock, sys.argv[2:])
        elif cmd == "switch":
            if len(sys.argv) < 3:
                print("Usage: bosectl switch <name>", file=sys.stderr)
                sys.exit(1)
            cmd_switch(sock, sys.argv[2])
        elif cmd == "dump":
            cmd_dump(sock)
        elif cmd == "modeconfig":
            idx = int(sys.argv[2]) if len(sys.argv) > 2 else 0
            cmd_modeconfig(sock, idx)
        elif cmd == "cnc":
            if len(sys.argv) < 3:
                print("Usage: bosectl cnc <0-10>", file=sys.stderr)
                sys.exit(1)
            cmd_cnc(sock, sys.argv[2])
        elif cmd == "eq":
            cmd_eq(sock, sys.argv[2:])
        elif cmd == "name":
            cmd_name(sock, sys.argv[2:])
        elif cmd == "sidetone":
            cmd_sidetone(sock, sys.argv[2:])
        elif cmd == "multipoint":
            cmd_toggle(sock, 10, "multipoint", sys.argv[2:])
        elif cmd == "autopause":
            cmd_toggle(sock, 24, "autopause", sys.argv[2:])
        elif cmd == "autoanswer":
            cmd_toggle(sock, 27, "autoanswer", sys.argv[2:])
        elif cmd == "prompts":
            cmd_prompts(sock, sys.argv[2:])
        elif cmd == "spatial":
            if len(sys.argv) < 3:
                print("Usage: bosectl spatial <off|room|head>", file=sys.stderr)
                sys.exit(1)
            cmd_spatial(sock, sys.argv[2].lower())
        elif cmd == "buttons":
            cmd_buttons(sock)
        elif cmd == "pair":
            cmd_pair(sock)
        elif cmd == "off":
            cmd_off(sock)
        elif cmd == "raw":
            if len(sys.argv) < 3:
                print("Usage: bosectl raw <hex>", file=sys.stderr)
                sys.exit(1)
            cmd_raw(sock, " ".join(sys.argv[2:]))
        else:
            # Try as a custom profile name
            cmd_switch(sock, sys.argv[1])
    finally:
        sock.close()


if __name__ == "__main__":
    main()
