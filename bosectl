#!/usr/bin/env python3
"""Control Bose QC Ultra 2 headphones over Bluetooth.

Communicates via the BMAP (Bose Messaging and Protocol) protocol over
Bluetooth SPP/RFCOMM channel 2. No Bose app, account, or cloud required.

BMAP packet format:
    [fblock_id, function_id, flags, payload_length, ...payload]
    flags = (device_id << 6) | (port_num << 4) | (operator & 0x0F)

The protocol is organized into function blocks (groups of features) and
operators (what to do). Key blocks:
    Block 0:  ProductInfo  — firmware, serial, MAC, product name
    Block 1:  Settings     — EQ, CNC, buttons, sidetone, multipoint, name
    Block 2:  Status       — battery level
    Block 4:  DeviceMgmt   — pairing, connected devices
    Block 5:  AudioMgmt    — audio routing, codec info
    Block 7:  Control      — power on/off
    Block 18: Auth         — ECDH cloud authentication (not needed for SETGET)
    Block 31: AudioModes   — mode switching, per-mode config (CNC, spatial, etc.)

Auth bypass: Bose gates SET (op 0) and START (op 5) behind cloud-mediated
ECDH authentication on most blocks, but SETGET (op 2) is unauthenticated.
START on block 31 (AudioModes) is also unauthenticated. This gives us full
read/write access to nearly every setting.

Tested against Bose QC Ultra 2 HP (codename "wolverine", Qualcomm QCC-384)
running firmware 8.2.20. The BMAP protocol is shared across Bose's Bluetooth
product line, so other models likely use similar function blocks — but specific
function IDs and payload formats may differ.

Written in Python for quick prototyping with the standard library's built-in
Bluetooth socket support (AF_BLUETOOTH). No external dependencies. A more
polished implementation could use C, Rust, or Go with direct RFCOMM access.

See NOTES.md for complete protocol documentation.
"""

import os
import socket
import subprocess
import struct
import sys
import time

# ── ANSI Colors ───────────────────────────────────────────────────────────────
# Only enable colors if stdout is a terminal (not piped).
if sys.stdout.isatty():
    C_RESET = "\033[0m"
    C_BOLD  = "\033[1m"
    C_DIM   = "\033[2m"
    C_CYAN  = "\033[36m"
    C_GREEN = "\033[32m"
    C_YELLOW = "\033[33m"
    C_RED   = "\033[31m"
    C_MAGENTA = "\033[35m"
    C_WHITE = "\033[97m"
else:
    C_RESET = C_BOLD = C_DIM = C_CYAN = C_GREEN = ""
    C_YELLOW = C_RED = C_MAGENTA = C_WHITE = ""

# Color gradient for the banner: cycles through cyan → blue → magenta
_GRAD = ["\033[96m", "\033[36m", "\033[34m", "\033[35m", "\033[95m"]
_BANNER_LINES = [
    r"    __                         __  __",
    r"   / /_  ____  ________  _____/ /_/ /",
    r"  / __ \/ __ \/ ___/ _ \/ ___/ __/ / ",
    r" / /_/ / /_/ (__  )  __/ /__/ /_/ /  ",
    r"/_.___/\____/____/\___/\___/\__/_/   ",
]
BANNER = "\n".join(
    f"{C_BOLD}{_GRAD[i]}{line}{C_RESET}" for i, line in enumerate(_BANNER_LINES)
) + f"\n{C_DIM}  Bose QC Ultra 2 — no app, no cloud, no account{C_RESET}\n"


# ── Configuration ─────────────────────────────────────────────────────────────
CHANNEL = 2  # BMAP protocol is always on RFCOMM channel 2


def find_bose_device():
    """Auto-detect a paired Bose headphone via bluetoothctl.

    Searches paired Bluetooth devices for names containing "Bose".
    Returns the MAC address string, or None if not found.
    """
    try:
        result = subprocess.run(
            ["bluetoothctl", "devices", "Paired"],
            capture_output=True, text=True, timeout=5
        )
        for line in result.stdout.strip().splitlines():
            # Format: "Device XX:XX:XX:XX:XX:XX Name Here"
            parts = line.split(None, 2)
            if len(parts) >= 3 and "bose" in parts[2].lower():
                return parts[1]
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return None


def get_bose_mac():
    """Get the Bose device MAC address.

    Priority: BOSE_MAC environment variable > auto-detection > error.
    Set BOSE_MAC=XX:XX:XX:XX:XX:XX to skip auto-detection.
    """
    env_mac = os.environ.get("BOSE_MAC")
    if env_mac:
        return env_mac

    mac = find_bose_device()
    if mac:
        return mac

    print(f"{C_RED}No Bose device found.{C_RESET}", file=sys.stderr)
    print(f"Pair your headphones via bluetoothctl, or set BOSE_MAC=XX:XX:XX:XX:XX:XX", file=sys.stderr)
    sys.exit(1)

# ── BMAP Operators ────────────────────────────────────────────────────────────
# Each BMAP packet carries an operator that says what to do.
# SET (0) and START (5) require cloud auth; SETGET (2) and GET (1) do not.
OP_SET = 0         # Write a value (auth required)
OP_GET = 1         # Read a value (no auth)
OP_SETGET = 2      # Write + read back (no auth — this is the bypass)
OP_STATUS = 3      # Unsolicited state notification from headphones
OP_ERROR = 4       # Error response
OP_START = 5       # Trigger an action (no auth on block 31)
OP_RESULT = 6      # Action completed successfully
OP_PROCESSING = 7  # Async operation in progress

OP_NAMES = {0: "SET", 1: "GET", 2: "SETGET", 3: "STATUS", 4: "ERROR",
             5: "START", 6: "RESULT", 7: "PROCESSING"}

# BMAP error codes returned in ERROR (op 4) responses.
# Error 5 (OpNotSupp) means authentication is required.
# Error 8 (Runtime) means the payload format is wrong or the operation
# can't be performed on this target (e.g., writing to a preset mode).
ERROR_NAMES = {0: "Unknown", 1: "Length", 2: "Chksum", 3: "FblockNotSupp",
               4: "FuncNotSupp", 5: "OpNotSupp(auth)", 6: "InvalidData",
               7: "DataUnavail", 8: "Runtime", 9: "Timeout", 10: "InvalidState",
               20: "InsecureTransport"}

# ── Audio Modes ───────────────────────────────────────────────────────────────
# The headphones have 11 mode slots (indices 0-10).
# Modes 0-3 are firmware presets (locked, cannot be modified).
# Mode 4+ are user-editable — the Bose app creates "Home" at slot 4.
# Slots 5-10 are empty by default and can be freely configured.
# To change settings like CNC or spatial audio, we write to an editable slot
# via ModeConfig SETGET [31.6], then switch to it via CurrentMode START [31.3].
MODES = {
    "quiet": (0, "Quiet — full ANC"),
    "aware": (1, "Aware — transparency"),
    "immersion": (2, "Immersion — spatial audio, head tracking"),
    "cinema": (3, "Cinema — spatial audio, fixed stage"),
    "home": (4, "Home — custom profile"),
}

MODE_BY_IDX = {i: n for n, (i, _) in MODES.items()}

# ── Voice Prompts ─────────────────────────────────────────────────────────────
# Each mode has a 2-byte voice prompt identifier that determines what the
# headphones say when switching to that mode. (byte1, byte2) -> name.
PROMPTS = {
    (0, 0): "NONE", (0, 1): "QUIET", (0, 2): "AWARE", (0, 3): "TRANSPARENT",
    (0, 4): "TRANSPARENCY", (0, 5): "MASKING", (0, 6): "COMFORT",
    (0, 7): "COMMUTE", (0, 8): "OUTDOOR", (0, 9): "WORKOUT", (0, 10): "HOME",
    (0, 11): "WORK", (0, 12): "MUSIC", (0, 13): "FOCUS", (0, 14): "RELAX",
    (0, 15): "FLIGHT", (0, 16): "AIRPORT", (0, 17): "DRIVING",
    (0, 18): "TRAINING", (0, 19): "GYM", (0, 20): "RUN", (0, 21): "WALK",
    (0, 22): "HIKE", (0, 23): "TALK", (0, 24): "CALL", (0, 25): "WHISPER",
    (0, 26): "HEARING", (0, 27): "LEARN", (0, 28): "PODCAST",
    (0, 29): "AUDIOBOOK", (0, 30): "CALM", (0, 31): "SLEEP",
    (0, 32): "MEDITATE", (0, 33): "YOGA", (0, 34): "IMMERSION",
    (0, 35): "STEREO", (0, 36): "CINEMA",
}

PROMPT_BY_NAME = {v.lower(): k for k, v in PROMPTS.items()}

SPATIAL_NAMES = {0: "off", 1: "room", 2: "head"}


# ── Transport ─────────────────────────────────────────────────────────────────

def connect():
    """Open a Bluetooth RFCOMM connection to the headphones.

    Uses Python's built-in socket module with AF_BLUETOOTH — no external
    Bluetooth libraries needed. The headphones must already be paired via
    bluetoothctl or similar. Only one RFCOMM connection can be active at a
    time; the Bose app must be disconnected/uninstalled to avoid conflicts.
    """
    mac = get_bose_mac()
    sock = socket.socket(socket.AF_BLUETOOTH, socket.SOCK_STREAM, socket.BTPROTO_RFCOMM)
    sock.settimeout(3)
    sock.connect((mac, CHANNEL))
    return sock


# ── BMAP Protocol ─────────────────────────────────────────────────────────────

def bmap_packet(fblock, func, operator, payload=b""):
    """Build a 4-byte BMAP header + payload.

    Packet layout: [fblock_id, function_id, flags, payload_length, ...payload]
    The flags byte encodes device_id (bits 7-6), port_num (bits 5-4), and
    operator (bits 3-0). We always use device_id=0, port_num=0.

    Example: bmap_packet(31, 3, OP_START, bytes([0, 0]))
      → [0x1f, 0x03, 0x05, 0x02, 0x00, 0x00]
      → AudioModes.CurrentMode START with payload [mode=0, prompt=0]
    """
    flags = operator & 0x0F
    return bytes([fblock, func, flags, len(payload)]) + payload


def send_recv(sock, packet, drain=False):
    """Send a BMAP packet and receive the response.

    Args:
        sock: Connected Bluetooth socket.
        packet: Raw bytes to send (from bmap_packet()).
        drain: If True, keep reading until the socket times out. Needed for
               commands like GetAll [31.1] that return multiple STATUS messages
               asynchronously after an initial PROCESSING response.

    Returns:
        Raw response bytes. May contain multiple concatenated BMAP packets
        if drain=True — use parse_all_responses() to split them.
    """
    sock.send(packet)
    time.sleep(0.2)
    data = sock.recv(4096)
    if drain:
        sock.settimeout(0.5)
        try:
            while True:
                more = sock.recv(4096)
                if not more:
                    break
                data += more
        except (socket.timeout, BlockingIOError):
            pass
        sock.settimeout(3)
    return data


def parse_response(data):
    """Parse a single BMAP response into (fblock, func, operator, payload).

    Returns None if the data is too short to contain a valid packet.
    The operator field tells you what kind of response this is:
        STATUS (3) = successful read/notification
        ERROR (4)  = something went wrong (check payload[0] for error code)
        RESULT (6) = action completed (e.g., mode switch)
    """
    if len(data) < 4:
        return None
    fblock = data[0]
    func = data[1]
    op = data[2] & 0x0F
    length = data[3]
    payload = data[4:4+length]
    return fblock, func, op, payload


def parse_all_responses(data):
    """Parse concatenated BMAP responses into a list of (fblock, func, op, payload).

    When drain=True is used with send_recv(), the headphones may send back
    multiple packets (e.g., GetAll returns one STATUS per mode). This splits
    them using each packet's length field.
    """
    responses = []
    pos = 0
    while pos < len(data) - 3:
        fblock = data[pos]
        func = data[pos + 1]
        op = data[pos + 2] & 0x0F
        length = data[pos + 3]
        payload = data[pos + 4:pos + 4 + length]
        responses.append((fblock, func, op, payload))
        pos += 4 + length
    return responses


def fmt_response(fblock, func, op, payload):
    """Format a parsed BMAP response as a human-readable string.

    Example: "[31.3] RESULT: 00" or "[1.5] ERROR: OpNotSupp(auth) (05)"
    """
    op_name = OP_NAMES.get(op, f"op{op}")
    if op == OP_ERROR and payload:
        err_name = ERROR_NAMES.get(payload[0], f"err{payload[0]}")
        return f"[{fblock}.{func}] {op_name}: {err_name} ({payload.hex()})"
    return f"[{fblock}.{func}] {op_name}: {payload.hex()}"


# ── Mode Config Encoding ─────────────────────────────────────────────────────

def encode_mode_name(name):
    """Encode a mode name as a 32-byte null-terminated, null-padded array.

    The firmware stores mode names as fixed 32-byte fields. Names longer
    than 31 bytes are truncated. The result is always exactly 32 bytes.
    """
    name_bytes = name.encode("utf-8")
    buf = bytearray(32)
    end = min(len(name_bytes), 31)
    buf[:end] = name_bytes[:end]
    buf[end] = 0
    return bytes(buf)


def build_modeconfig_payload(mode_idx, prompt_b1, prompt_b2, name, cnc_level,
                              auto_cnc, spatial=0, wind_block=0, anc_toggle=0):
    """Build a 40-byte ModeConfig SETGET payload for writing to [31.6].

    This is the packet the headphones expect when configuring a mode slot.
    Only works on editable slots (index 4-10, where flags[3]=0x01).
    Preset modes (0-3) will return Runtime error 8.

    Layout:
        [0]     mode_idx       — slot index (4-10 for editable)
        [1:3]   prompt         — voice prompt ID (byte1, byte2)
        [3:35]  name           — 32-byte null-padded UTF-8 mode name
        [35]    cnc_level      — noise cancellation 0-10
        [36]    auto_cnc       — auto CNC adjustment (0 or 1)
        [37]    spatial        — spatial audio: 0=off, 1=room, 2=head
        [38]    wind_block     — wind noise reduction (0 or 1)
        [39]    anc_toggle     — ANC toggle enable (0 or 1)

    Send via: bmap_packet(31, 6, OP_SETGET, payload)
    """
    payload = bytearray()
    payload.append(mode_idx)
    payload.append(prompt_b1)
    payload.append(prompt_b2)
    payload.extend(encode_mode_name(name))
    payload.append(cnc_level)
    payload.append(1 if auto_cnc else 0)
    payload.append(spatial)
    payload.append(1 if wind_block else 0)
    payload.append(1 if anc_toggle else 0)
    return bytes(payload)


def parse_modeconfig(payload):
    """Parse a ModeConfig STATUS/RESULT payload.

    STATUS response format (48 bytes):
      [0]    modeIndex
      [1:3]  prompt (byte1, byte2)
      [3:6]  flags (3 bytes — editability/user mode flags?)
      [6:38] name (32 bytes, null-padded UTF-8)
      [38]   cncLevel (0-10)
      [39]   autoCNC (bool)
      [40:44] unknown (4 bytes — mode-specific config?)
      [44]   spatialAudioType (0=off, 1=room, 2=head)
      [45]   windBlock (bool)
      [46]   ancToggle (bool)
      [47]   unknown (always 0x01?)

    SETGET input payload (40 bytes, from APK):
      [0]    modeIndex
      [1:3]  prompt (byte1, byte2)
      [3:35] name (32 bytes)
      [35]   cncLevel
      [36]   autoCNC
      [37]   spatialAudioType
      [38]   windBlock
      [39]   ancToggle
    """
    if len(payload) < 6:
        return {"raw": payload.hex(), "error": f"too short ({len(payload)} bytes)"}
    mode_idx = payload[0]
    prompt_b1 = payload[1]
    prompt_b2 = payload[2]
    prompt_name = PROMPTS.get((prompt_b1, prompt_b2), f"({prompt_b1},{prompt_b2})")

    # STATUS has 3 flag bytes between prompt and name
    if len(payload) >= 48:
        flags = payload[3:6]
        name_bytes = payload[6:38]
        name = name_bytes.split(b"\x00", 1)[0].decode("utf-8", errors="replace")
        config = {
            "mode_idx": mode_idx,
            "mode_name": MODE_BY_IDX.get(mode_idx, f"custom({mode_idx})"),
            "prompt": prompt_name,
            "flags": f"{flags[0]:02x} {flags[1]:02x} {flags[2]:02x}",
            "name": name,
            "cnc_level": payload[38],
            "auto_cnc": bool(payload[39]),
            "unknown_40_43": payload[40:44].hex(),
            "spatial": SPATIAL_NAMES.get(payload[44], payload[44]),
            "wind_block": bool(payload[45]),
            "anc_toggle": bool(payload[46]),
        }
        if len(payload) > 47:
            config["tail"] = payload[47:].hex()
        return config

    # Short/SETGET format (no flag bytes, name at offset 3)
    name_bytes = payload[3:35] if len(payload) >= 35 else payload[3:]
    name = name_bytes.split(b"\x00", 1)[0].decode("utf-8", errors="replace")
    config = {
        "mode_idx": mode_idx,
        "mode_name": MODE_BY_IDX.get(mode_idx, f"custom({mode_idx})"),
        "prompt": prompt_name,
        "name": name,
        "raw": payload.hex(),
    }
    return config


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_mode(sock, mode_name):
    """Switch to a preset audio mode by name.

    Sends CurrentMode START [31.3] with [mode_index, voice_prompt].
    The second byte controls whether the headphones play a voice prompt
    (0=silent, 1=speak the mode name).

    This uses the unauthenticated START operator on block 31.
    """
    idx, desc = MODES[mode_name]
    resp = send_recv(sock, bmap_packet(31, 3, OP_START, bytes([idx, 0])))
    parsed = parse_response(resp)
    if parsed and parsed[2] == OP_RESULT:
        print(f"OK: {desc}")
    else:
        print(f"FAIL: {desc}")
        if parsed:
            print(f"  {fmt_response(*parsed)}")


def cmd_status(sock):
    """Show all current headphone settings.

    Reads from multiple function blocks:
        [2.2]  Battery level (percentage)
        [31.3] Current audio mode
        [1.5]  CNC level (noise cancellation, 0-10)
        [1.7]  EQ (3-band: bass/mid/treble, -10 to +10)
        [1.2]  Device name (first byte is a flag, name starts at byte 1)
        [0.5]  Firmware version
        [1.11] Sidetone level
        [1.10] Multipoint toggle (bit 1 of response byte)
        [1.24] Auto play/pause toggle
        [1.3]  Voice prompts (bit 5 = enabled, bits 4-0 = language ID)
    """
    def row(label, value, color=C_WHITE):
        print(f"  {C_DIM}{label:12s}{C_RESET} {color}{value}{C_RESET}")

    # Battery
    resp = send_recv(sock, bmap_packet(2, 2, OP_GET))
    batt = resp[4]
    batt_color = C_GREEN if batt > 30 else C_YELLOW if batt > 10 else C_RED
    row("Battery", f"{batt}%", batt_color)

    # Current mode
    resp = send_recv(sock, bmap_packet(31, 3, OP_GET))
    mode_idx = resp[4]
    mode_name = MODE_BY_IDX.get(mode_idx)
    if not mode_name:
        modes = get_all_modes(sock)
        if mode_idx in modes:
            mode_name = modes[mode_idx][1].get("name", f"unknown({mode_idx})")
        else:
            mode_name = f"unknown({mode_idx})"
    row("Mode", mode_name, C_CYAN)

    # CNC level
    resp = send_recv(sock, bmap_packet(1, 5, OP_GET))
    payload = resp[4:4+resp[3]]
    if len(payload) >= 3:
        cnc_val = payload[1]
        cnc_max = payload[0] - 1
        bar = "█" * cnc_val + "░" * (cnc_max - cnc_val)
        row("CNC", f"{bar} {cnc_val}/{cnc_max}")

    # EQ
    resp = send_recv(sock, bmap_packet(1, 7, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        bands = []
        for i in range(0, len(parsed[3]), 4):
            cur = parsed[3][i + 2]
            bands.append(f"{cur if cur < 128 else cur - 256:+d}")
        row("EQ", f"{'/'.join(bands)} (bass/mid/treble)")

    # Device name
    resp = send_recv(sock, bmap_packet(1, 2, OP_GET))
    name = resp[5:4+resp[3]].decode("utf-8", errors="replace")
    row("Name", name, C_BOLD)

    # Firmware
    resp = send_recv(sock, bmap_packet(0, 5, OP_GET))
    fw = resp[4:4+resp[3]].decode("ascii", errors="replace")
    row("FW", fw, C_DIM)

    # Sidetone
    resp = send_recv(sock, bmap_packet(1, 11, OP_GET))
    parsed = parse_response(resp)
    if parsed and len(parsed[3]) >= 2:
        row("Sidetone", SIDETONE_NAMES.get(parsed[3][1], parsed[3][1]))

    # Multipoint
    resp = send_recv(sock, bmap_packet(1, 10, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        on = bool(parsed[3][0] & 0x02)
        row("Multipoint", "on" if on else "off", C_GREEN if on else C_DIM)

    # Auto play/pause
    resp = send_recv(sock, bmap_packet(1, 24, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        on = bool(parsed[3][0])
        row("AutoPause", "on" if on else "off", C_GREEN if on else C_DIM)

    # Voice prompts
    resp = send_recv(sock, bmap_packet(1, 3, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        enabled = bool((parsed[3][0] >> 5) & 1)
        lang = parsed[3][0] & 0x1F
        row("Prompts", f"{'on' if enabled else 'off'} ({VOICE_LANGUAGES.get(lang, lang)})")


def cmd_battery(sock):
    """Print battery percentage as a bare number. Reads [2.2] BatteryLevel."""
    resp = send_recv(sock, bmap_packet(2, 2, OP_GET))
    print(resp[4])


def cmd_current(sock):
    """Print current mode name as a bare word. Reads [31.3] CurrentMode."""
    resp = send_recv(sock, bmap_packet(31, 3, OP_GET))
    mode_idx = resp[4]
    if mode_idx in MODE_BY_IDX:
        print(MODE_BY_IDX[mode_idx])
    else:
        # Look up custom profile name
        modes = get_all_modes(sock)
        if mode_idx in modes:
            print(modes[mode_idx][1].get("name", f"unknown({mode_idx})"))
        else:
            print(f"unknown({mode_idx})")


def get_all_modes(sock):
    """Read all mode configs by triggering AudioModes GetAll [31.1] START.

    Sends START on [31.1], which causes the headphones to reply with a
    PROCESSING acknowledgment followed by STATUS messages for every function
    in block 31 — including one ModeConfig [31.6] STATUS per mode slot.

    Returns: dict of mode_index -> (raw_payload_bytes, parsed_config_dict)
    """
    data = send_recv(sock, bmap_packet(31, 1, OP_START), drain=True)
    responses = parse_all_responses(data)
    modes = {}
    for fblock, func, op, payload in responses:
        if fblock == 31 and func == 6 and op == OP_STATUS and payload and len(payload) >= 6:
            config = parse_modeconfig(payload)
            modes[payload[0]] = (payload, config)
    return modes


def find_mode_by_name(modes, name):
    """Find a mode index by name (case-insensitive). Returns (idx, raw, config) or None."""
    name_lower = name.lower()
    for idx, (raw, config) in sorted(modes.items()):
        if config.get("name", "").lower() == name_lower:
            return idx, raw, config
    return None


def find_free_slot(modes):
    """Find the first unconfigured editable slot (5-10). Returns index or None.

    An empty slot has flags[4] (configured) = 0 and name "None" or empty.
    """
    for idx in range(5, 11):
        if idx in modes:
            raw, config = modes[idx]
            if raw[4] == 0 and config.get("name", "").lower() in ("none", ""):
                return idx
    return None


def write_mode(sock, mode_idx, name, cnc=0, spatial=0, wind_block=1, anc_toggle=1, prompt_b1=0, prompt_b2=0):
    """Write a mode config to an editable slot via ModeConfig SETGET [31.6].

    Builds a 40-byte payload and sends it as SETGET. The headphones reply
    with a STATUS containing the full 48-byte config if successful, or an
    ERROR if the slot is not editable (Runtime error 8 for preset modes).

    Returns True if the headphones acknowledged with a STATUS response.
    """
    payload = build_modeconfig_payload(
        mode_idx=mode_idx, prompt_b1=prompt_b1, prompt_b2=prompt_b2,
        name=name, cnc_level=cnc, auto_cnc=False,
        spatial=spatial, wind_block=wind_block, anc_toggle=anc_toggle
    )
    resp = send_recv(sock, bmap_packet(31, 6, OP_SETGET, payload), drain=True)
    parsed = parse_all_responses(resp)
    return any(r[2] == OP_STATUS for r in parsed)


def cmd_dump(sock):
    """Trigger AudioModes GetAll and show all status responses."""
    print("Triggering AudioModes GetAll (async)...")
    data = send_recv(sock, bmap_packet(31, 1, OP_START), drain=True)
    responses = parse_all_responses(data)
    for fblock, func, op, payload in responses:
        print(fmt_response(fblock, func, op, payload))
        if fblock == 31 and func == 6 and op == OP_STATUS:
            config = parse_modeconfig(payload)
            for k, v in config.items():
                print(f"    {k}: {v}")


def cmd_modeconfig(sock, mode_idx):
    """Read mode config via GetAll and filter to the requested mode."""
    data = send_recv(sock, bmap_packet(31, 1, OP_START), drain=True)
    responses = parse_all_responses(data)
    found = False
    for fblock, func, op, payload in responses:
        if fblock == 31 and func == 6 and op == OP_STATUS and payload and payload[0] == mode_idx:
            found = True
            print(f"[31.6] ModeConfig STATUS for mode {mode_idx}:")
            print(f"  raw: {payload.hex()}")
            config = parse_modeconfig(payload)
            for k, v in config.items():
                if k != "raw":
                    print(f"  {k}: {v}")
    if not found:
        print(f"No ModeConfig STATUS received for mode {mode_idx}")
        print("All responses:")
        for r in responses:
            print(f"  {fmt_response(*r)}")


def get_current_profile(sock, modes):
    """Get the current mode's index, raw payload, and config. Returns (idx, raw, config) or None."""
    resp = send_recv(sock, bmap_packet(31, 3, OP_GET))
    current = resp[4]
    if current in modes:
        raw, config = modes[current]
        return current, raw, config
    return current, None, None


def ensure_editable_profile(sock, modes):
    """Ensure we're on an editable profile. Returns (idx, raw, config).

    If the current mode is editable, returns it. Otherwise finds or creates
    a custom profile based on the current settings and switches to it.
    """
    idx, raw, config = get_current_profile(sock, modes)

    # If current mode is editable, use it directly
    if raw is not None and raw[3] == 1:  # flags[0] = editable
        return idx, raw, config

    # Current mode is a preset — need a custom slot
    # Look for an existing "Custom" profile first
    result = find_mode_by_name(modes, "Custom")
    if result:
        slot = result[0]
    else:
        slot = find_free_slot(modes)
    if slot is None:
        print("No free profile slot available (modes 5-10 all in use)", file=sys.stderr)
        sys.exit(1)

    # Read current CNC to carry over
    resp = send_recv(sock, bmap_packet(1, 5, OP_GET))
    cnc = resp[5] if len(resp) > 5 else 0

    return slot, None, {"name": "Custom", "cnc_level": cnc, "spatial": "off",
                        "wind_block": False, "anc_toggle": False}


def cmd_cnc(sock, level):
    """Set noise cancellation level (0-10) on the current profile.

    If already on an editable profile, modifies it in place. If on a preset
    mode (Quiet/Aware/etc.), finds or creates a "Custom" profile slot,
    writes the CNC level, and switches to it.

    CNC 0 = minimum cancellation, 10 = maximum cancellation.
    Uses ModeConfig SETGET [31.6] (no auth) + CurrentMode START [31.3].
    """
    level = int(level)
    if not 0 <= level <= 10:
        print("CNC level must be 0-10", file=sys.stderr)
        sys.exit(1)

    modes = get_all_modes(sock)
    slot, raw, config = ensure_editable_profile(sock, modes)

    # Read current settings from the STATUS response to preserve them
    if raw is not None and len(raw) >= 48:
        name = config.get("name", "Custom")
        spatial = raw[44]
        wind = raw[45]
        anc = raw[47]
        pb1, pb2 = raw[1], raw[2]
    else:
        name = config.get("name", "Custom")
        spatial, wind, anc = 0, 1, 1
        pb1, pb2 = 0, 0

    if not write_mode(sock, slot, name, cnc=level, spatial=spatial,
                      wind_block=wind, anc_toggle=anc, prompt_b1=pb1, prompt_b2=pb2):
        print("Failed to configure mode", file=sys.stderr)
        sys.exit(1)

    # Switch to the profile
    resp = send_recv(sock, bmap_packet(31, 3, OP_START, bytes([slot, 0])))
    parsed = parse_response(resp)
    if parsed and parsed[2] == OP_RESULT:
        print(f"CNC: {level}/10")
    else:
        print("Mode switch failed", file=sys.stderr)


def cmd_eq(sock, args):
    """Set 3-band equalizer via Settings RangeControl SETGET [1.7].

    Each band is -10 to +10. Payload is 2 bytes: [signed_value, band_id]
    where band 0=bass, 1=mid, 2=treble. The response includes all 3 bands
    as 4-byte groups: [min, max, current_level, band_id].

    'eq flat' resets all bands to 0.
    'eq' with no args shows current levels.
    """
    if not args or args[0] == "flat":
        values = [0, 0, 0]
    elif len(args) == 1 and args[0] == "get":
        values = None
    elif len(args) == 3:
        values = [int(x) for x in args]
        for v in values:
            if not -10 <= v <= 10:
                print("EQ values must be -10 to +10", file=sys.stderr)
                sys.exit(1)
    else:
        print("Usage: bosectl eq <bass> <mid> <treble>  (each -10 to +10)", file=sys.stderr)
        print("       bosectl eq flat                    (reset to 0/0/0)", file=sys.stderr)
        print("       bosectl eq                         (show current)", file=sys.stderr)
        sys.exit(1)

    band_names = {0: "Bass", 1: "Mid", 2: "Treble"}

    if values is not None:
        for band_id, val in enumerate(values):
            val_byte = val & 0xFF  # signed to unsigned byte
            send_recv(sock, bmap_packet(1, 7, OP_SETGET, bytes([val_byte, band_id])))

    # Read and display current EQ
    resp = send_recv(sock, bmap_packet(1, 7, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        payload = parsed[3]
        for i in range(0, len(payload), 4):
            cur = payload[i + 2]
            cur_signed = cur if cur < 128 else cur - 256
            bid = payload[i + 3]
            print(f"{band_names.get(bid, bid):6s}: {cur_signed:+d}")


def cmd_spatial(sock, setting):
    """Set spatial audio mode on current profile (or create a custom one).

    Spatial modes: off (stereo), room (fixed soundstage), head (head tracking).
    Uses ModeConfig SETGET [31.6] on the current editable profile.
    """
    spatial_map = {"off": 0, "room": 1, "head": 2}
    if setting not in spatial_map:
        print(f"Unknown spatial mode: {setting}. Use: off, room, head", file=sys.stderr)
        sys.exit(1)
    spatial = spatial_map[setting]

    modes = get_all_modes(sock)
    slot, raw, config = ensure_editable_profile(sock, modes)

    if raw is not None and len(raw) >= 48:
        name = config.get("name", "Custom")
        cnc = raw[42]
        wind = raw[45]
        anc = raw[47]
        pb1, pb2 = raw[1], raw[2]
    else:
        name = config.get("name", "Custom")
        cnc = config.get("cnc_level", 0)
        wind, anc = 1, 1
        pb1, pb2 = 0, 0

    if not write_mode(sock, slot, name, cnc=cnc, spatial=spatial,
                      wind_block=wind, anc_toggle=anc, prompt_b1=pb1, prompt_b2=pb2):
        print("Failed to configure mode", file=sys.stderr)
        sys.exit(1)

    resp = send_recv(sock, bmap_packet(31, 3, OP_START, bytes([slot, 0])))
    parsed = parse_response(resp)
    if parsed and parsed[2] == OP_RESULT:
        print(f"Spatial: {setting} (CNC: {cnc}/10)")
    else:
        print("Mode switch failed", file=sys.stderr)


def cmd_profiles(sock):
    """List all audio mode profiles."""
    modes = get_all_modes(sock)
    resp = send_recv(sock, bmap_packet(31, 3, OP_GET))
    current = resp[4]

    for idx in sorted(modes):
        raw, config = modes[idx]
        name = config.get("name", "")
        editable = raw[3] == 1 if len(raw) > 3 else False
        configured = raw[4] == 1 if len(raw) > 4 else False

        if not editable and not configured and idx > 4:
            continue  # Skip empty non-editable slots (shouldn't happen, but just in case)

        is_current = idx == current
        marker = f" {C_CYAN}*{C_RESET}" if is_current else ""
        tag = ""
        if not editable:
            tag = f" {C_DIM}[preset]{C_RESET}"
        elif not configured:
            tag = f" {C_DIM}[empty]{C_RESET}"

        name_color = C_BOLD + C_WHITE if is_current else C_WHITE if (editable and configured) else C_DIM
        line = f"  {C_DIM}{idx:2d}{C_RESET}  {name_color}{name:16s}{C_RESET}"

        # Show config for configured modes
        if configured or not editable:
            parts = []
            cnc = raw[42] if len(raw) > 42 else None
            spatial_val = raw[44] if len(raw) > 44 else None
            wind_val = raw[45] if len(raw) > 45 else None

            if cnc is not None:
                parts.append(f"cnc={cnc}")
            if spatial_val is not None and spatial_val > 0:
                parts.append(f"spatial={SPATIAL_NAMES.get(spatial_val, spatial_val)}")
            if wind_val:
                parts.append("wind=on")

            if parts:
                line += f"  {C_DIM}{' '.join(parts)}{C_RESET}"

        line += tag + marker
        print(line)


def cmd_profile_set(sock, args):
    """Create or update a named profile.

    Usage: bosectl profile set <name> [cnc=N] [spatial=off|room|head] [wind=on|off] [anc=on|off] [name=NEW]
    """
    if not args:
        print("Usage: bosectl profile set <name> [cnc=N] [spatial=off|room|head] "
              "[wind=on|off] [anc=on|off] [name=NEW]", file=sys.stderr)
        sys.exit(1)

    lookup_name = args[0]
    opts = {}
    for arg in args[1:]:
        if "=" not in arg:
            print(f"Invalid option: {arg} (expected key=value)", file=sys.stderr)
            sys.exit(1)
        k, v = arg.split("=", 1)
        opts[k.lower()] = v

    modes = get_all_modes(sock)

    # Check if profile already exists
    existing = find_mode_by_name(modes, lookup_name)
    if existing:
        slot, raw, config = existing
        if raw[3] != 1:
            print(f"Cannot modify preset mode '{lookup_name}'", file=sys.stderr)
            sys.exit(1)
        # Preserve existing values as defaults
        cnc = raw[42] if len(raw) > 42 else 0
        spatial = raw[44] if len(raw) > 44 else 0
        wind = raw[45] if len(raw) > 45 else 1
        anc = raw[47] if len(raw) > 47 else 1
        pb1, pb2 = raw[1], raw[2]
    else:
        # Find a free slot
        slot = find_free_slot(modes)
        if slot is None:
            print("No free profile slot available (modes 5-10 all in use)", file=sys.stderr)
            sys.exit(1)
        cnc, spatial, wind, anc = 0, 0, 1, 1
        pb1, pb2 = 0, 0

    # Allow renaming via name= option
    new_name = opts.pop("name", lookup_name)

    spatial_map = {"off": 0, "room": 1, "head": 2}
    bool_map = {"on": 1, "off": 0, "1": 1, "0": 0, "true": 1, "false": 0}

    if "cnc" in opts:
        cnc = int(opts["cnc"])
        if not 0 <= cnc <= 10:
            print("cnc must be 0-10", file=sys.stderr)
            sys.exit(1)
    if "spatial" in opts:
        if opts["spatial"] not in spatial_map:
            print("spatial must be off, room, or head", file=sys.stderr)
            sys.exit(1)
        spatial = spatial_map[opts["spatial"]]
    if "wind" in opts:
        if opts["wind"].lower() not in bool_map:
            print("wind must be on or off", file=sys.stderr)
            sys.exit(1)
        wind = bool_map[opts["wind"].lower()]
    if "anc" in opts:
        if opts["anc"].lower() not in bool_map:
            print("anc must be on or off", file=sys.stderr)
            sys.exit(1)
        anc = bool_map[opts["anc"].lower()]

    if not write_mode(sock, slot, new_name, cnc=cnc, spatial=spatial,
                      wind_block=wind, anc_toggle=anc, prompt_b1=pb1, prompt_b2=pb2):
        print("Failed to write profile", file=sys.stderr)
        sys.exit(1)

    action = "Updated" if existing else f"Created (slot {slot})"
    if new_name != lookup_name and existing:
        action = f"Renamed {lookup_name} ->"
    print(f"{action}: {new_name}  cnc={cnc} spatial={SPATIAL_NAMES.get(spatial, spatial)} "
          f"wind={'on' if wind else 'off'} anc={'on' if anc else 'off'}")


def cmd_profile_rm(sock, name):
    """Delete a custom profile by resetting its slot to empty."""
    modes = get_all_modes(sock)
    existing = find_mode_by_name(modes, name)
    if not existing:
        print(f"Profile '{name}' not found", file=sys.stderr)
        sys.exit(1)

    slot, raw, config = existing
    if raw[3] != 1:
        print(f"Cannot delete preset mode '{name}'", file=sys.stderr)
        sys.exit(1)

    if not write_mode(sock, slot, "None", cnc=0, spatial=0, wind_block=0, anc_toggle=0):
        print("Failed to reset profile", file=sys.stderr)
        sys.exit(1)

    print(f"Deleted: {name} (slot {slot})")


def cmd_switch(sock, name):
    """Switch to a mode by name (works for both presets and custom profiles)."""
    # Check preset modes first
    name_lower = name.lower()
    if name_lower in MODES:
        cmd_mode(sock, name_lower)
        return

    # Look up custom profiles
    modes = get_all_modes(sock)
    existing = find_mode_by_name(modes, name)
    if not existing:
        print(f"Unknown mode or profile: {name}", file=sys.stderr)
        print("Presets: " + ", ".join(MODES.keys()), file=sys.stderr)
        custom = [c.get("name") for _, (r, c) in modes.items()
                  if r[3] == 1 and r[4] == 1 and c.get("name", "").lower() not in ("none", "")]
        if custom:
            print("Profiles: " + ", ".join(custom), file=sys.stderr)
        sys.exit(1)

    idx = existing[0]
    resp = send_recv(sock, bmap_packet(31, 3, OP_START, bytes([idx, 0])))
    parsed = parse_response(resp)
    if parsed and parsed[2] == OP_RESULT:
        print(f"OK: {name}")
    else:
        print(f"Failed to switch to {name}", file=sys.stderr)


def cmd_name(sock, args):
    """Get or set device Bluetooth name via Settings ProductName SETGET [1.2].

    The GET response has a leading flag byte (0x00) before the UTF-8 name.
    The SETGET payload is just the raw UTF-8 string (no flag byte).
    Accepts any UTF-8 string — not limited to the Bose app's preset list.
    """
    if args:
        name = " ".join(args).encode("utf-8")
        send_recv(sock, bmap_packet(1, 2, OP_SETGET, name))

    resp = send_recv(sock, bmap_packet(1, 2, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        name = parsed[3][1:].decode("utf-8", errors="replace")
        print(name)


SIDETONE_MODES = {"off": 0, "high": 1, "medium": 2, "med": 2, "low": 3}
SIDETONE_NAMES = {0: "off", 1: "high", 2: "medium", 3: "low"}


def cmd_sidetone(sock, args):
    """Get or set sidetone level via Settings Sidetone SETGET [1.11].

    Sidetone controls how much of your own voice you hear through the
    headphones during calls. Payload: [persist_flag, mode] where mode
    is 0=off, 1=high, 2=medium, 3=low. The persist flag (byte 0) is
    set to 1 to save across power cycles.
    """
    if args:
        mode = args[0].lower()
        if mode not in SIDETONE_MODES:
            print(f"Unknown sidetone mode. Use: off, low, medium, high", file=sys.stderr)
            sys.exit(1)
        send_recv(sock, bmap_packet(1, 11, OP_SETGET, bytes([1, SIDETONE_MODES[mode]])))

    resp = send_recv(sock, bmap_packet(1, 11, OP_GET))
    parsed = parse_response(resp)
    if parsed and len(parsed[3]) >= 2:
        print(SIDETONE_NAMES.get(parsed[3][1], f"unknown({parsed[3][1]})"))


def cmd_toggle(sock, func, label, args):
    """Generic on/off toggle for single-byte boolean Settings SETGET.

    Used for multipoint [1.10], auto-play/pause [1.24], and auto-answer [1.27].
    Payload: single byte, 0=off, 1=on.
    Note: multipoint [1.10] encodes enabled as bit 1 (0x02) in the response,
    not bit 0, because the byte is a capability bitmask.
    """
    if args:
        val = args[0].lower()
        if val in ("on", "1", "true", "yes"):
            send_recv(sock, bmap_packet(1, func, OP_SETGET, bytes([1])))
        elif val in ("off", "0", "false", "no"):
            send_recv(sock, bmap_packet(1, func, OP_SETGET, bytes([0])))
        else:
            print(f"Usage: bosectl{label} [on|off]", file=sys.stderr)
            sys.exit(1)

    resp = send_recv(sock, bmap_packet(1, func, OP_GET))
    parsed = parse_response(resp)
    if parsed:
        # Multipoint [1.10] has a bitfield: bit1=enabled
        if func == 10:
            val = bool(parsed[3][0] & 0x02)
        else:
            val = bool(parsed[3][0])
        print(f"{'on' if val else 'off'}")


